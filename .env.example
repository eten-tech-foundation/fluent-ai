# ── Application ───────────────────────────────────────────────────────────────
APP_NAME=Fluent AI API
APP_VERSION=0.1.0
PORT=8200

# ── Database (for host tools like psql) ──────────────────────────────────────
# Container networking overrides this in compose.yaml
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/fluent

# ── Security ─────────────────────────────────────────────────────────────────
SECRET_KEY=dev-secret-key-not-for-production

# ── External AI Services ─────────────────────────────────────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
