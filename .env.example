# ── Application ───────────────────────────────────────────────────────────────
APP_NAME=Fluent AI API
APP_VERSION=0.1.0
PORT=8200

# ── Database (for host tools like psql) ──────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://ai_user:password@db:5432/fluent

# ── Security ─────────────────────────────────────────────────────────────────
SECRET_KEY=dev-secret-key-not-for-production

# ── Development API key ───────────────────────────────────────────────────────
# Seeded automatically on first DB start. Use in X-API-Key header locally.
# Never use this key outside of local development.
DEV_API_KEY=fai_dev_admin

# ── External AI Services ─────────────────────────────────────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
