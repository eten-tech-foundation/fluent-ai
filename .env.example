PORT=8200

# ── Database (for host tools like psql) ──────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://ai_user:password@db:5432/fluent

# ── Security ─────────────────────────────────────────────────────────────────
SECRET_KEY=dev-secret-key-not-for-production

# ── External AI Services ─────────────────────────────────────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_AI_API_KEY=
GOOGLE_AI_MODEL=gemini-2.5-flash-lite
