# Production Environment Configuration
# Copy to .env.prod and customize with real values

# Application Settings
APP_NAME=Fluent AI API
APP_VERSION=0.1.0
PORT=8200

# Security - MUST change in production
SECRET_KEY=generate-a-strong-secret-key-here

# Database Configuration - Use managed database in production
DATABASE_URL=postgresql+asyncpg://user:password@your-production-db-host:5432/fluent_ai

# External AI Services
OPENAI_API_KEY=your-openai-api-key
ANTHROPIC_API_KEY=your-anthropic-api-key
