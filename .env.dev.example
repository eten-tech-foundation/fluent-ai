# Development Environment Configuration
# Copy to .env.dev and customize

# Application Settings
APP_NAME=Fluent AI API
APP_VERSION=0.1.0
PORT=8200

# Security
SECRET_KEY=dev-secret-key-not-for-production

# Database Configuration
# Option 1: Use cloud-based development database (default)
DATABASE_URL=postgresql+asyncpg://user:password@your-cloud-db-host:5432/fluent_ai_dev

# Option 2: Use local containerized PostgreSQL (run with --local-db flag)
# DATABASE_URL=postgresql+asyncpg://fluent:fluent@db:5432/fluent_ai

# Local DB port mapping (only used with --profile local-db)
DB_PORT=5432

# External AI Services
OPENAI_API_KEY=your-openai-api-key
ANTHROPIC_API_KEY=your-anthropic-api-key
